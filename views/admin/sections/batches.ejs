<section class="admin-panel">
  <div class="panel-head">
    <h2>Batches</h2>
    <span class="panel-count"><%= batches.length %> batches</span>
  </div>

  <div class="admin-grid-2">
    <article class="card">
      <h3>Create Batch</h3>
      <form class="grid cols-3 form-grid" method="post" action="/admin/batches">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>
          Batch Name *
          <input type="text" name="name" required />
        </label>
        <label>
          Class *
          <select name="classLevel" required>
            <option value="">Select class</option>
            <option value="9">Class 9</option>
            <option value="10">Class 10</option>
            <option value="11">Class 11</option>
            <option value="12">Class 12</option>
          </select>
        </label>
        <label>
          Capacity
          <input type="number" name="capacity" min="1" max="500" value="20" />
        </label>
        <label>
          Timing
          <input type="text" name="timing" placeholder="6:00 PM - 7:00 PM" />
        </label>
        <label>
          Days
          <input type="text" name="days" placeholder="Mon-Wed-Fri" />
        </label>
        <label>
          Status
          <select name="status">
            <option value="active">Active</option>
            <option value="paused">Paused</option>
          </select>
        </label>
        <div class="full">
          <button type="submit" class="btn">Create Batch</button>
        </div>
      </form>
    </article>

    <article class="card">
      <h3>Batch List</h3>
      <% if (!batches.length) { %>
        <p class="muted">No batches yet.</p>
      <% } else { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Class</th>
                <th>Timing</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% batches.forEach((batch) => { %>
                <tr>
                  <td><%= batch.name %></td>
                  <td><%= batch.classLevel %></td>
                  <td><%= batch.timing || '-' %></td>
                  <td><span class="pill <%= batch.status === 'active' ? 'p-active' : 'p-inactive' %>"><%= batch.status %></span></td>
                  <td><a href="#batch-<%= batch._id %>" class="table-link">Edit</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </article>
  </div>

  <div class="stack">
    <% batches.forEach((batch) => { %>
      <details class="editor-card" id="batch-<%= batch._id %>">
        <summary>
          <span><strong><%= batch.name %></strong> (Class <%= batch.classLevel %>)</span>
          <span class="muted">Edit batch</span>
        </summary>
        <div class="editor-body">
          <form method="post" action="/admin/batches/<%= batch._id %>?_method=PATCH" class="grid cols-3 form-grid">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label>
              Batch Name
              <input type="text" name="name" value="<%= batch.name %>" required />
            </label>
            <label>
              Class
              <select name="classLevel" required>
                <option value="9" <%= batch.classLevel === '9' ? 'selected' : '' %>>9</option>
                <option value="10" <%= batch.classLevel === '10' ? 'selected' : '' %>>10</option>
                <option value="11" <%= batch.classLevel === '11' ? 'selected' : '' %>>11</option>
                <option value="12" <%= batch.classLevel === '12' ? 'selected' : '' %>>12</option>
              </select>
            </label>
            <label>
              Capacity
              <input type="number" name="capacity" value="<%= batch.capacity %>" />
            </label>
            <label>
              Timing
              <input type="text" name="timing" value="<%= batch.timing || '' %>" />
            </label>
            <label>
              Days
              <input type="text" name="days" value="<%= batch.days || '' %>" />
            </label>
            <label>
              Status
              <select name="status">
                <option value="active" <%= batch.status === 'active' ? 'selected' : '' %>>Active</option>
                <option value="paused" <%= batch.status === 'paused' ? 'selected' : '' %>>Paused</option>
              </select>
            </label>
            <div class="btn-row full">
              <button type="submit" class="btn">Save Changes</button>
            </div>
          </form>
          <form method="post" action="/admin/batches/<%= batch._id %>?_method=DELETE">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn btn-danger js-confirm" data-confirm="Delete this batch?">Delete Batch</button>
          </form>
        </div>
      </details>
    <% }) %>
  </div>
</section>
