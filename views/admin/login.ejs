<div class="admin-login-wrap">
  <div class="login-card">
    <div class="lc-logo">
      <div class="lc-icon">&#x1F510;</div>
      <h2>Admin Login</h2>
      <p>Akram's Bio-Care - Staff Access Only</p>
    </div>

    <form method="post" action="/admin/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input class="login-inp" type="email" name="email" placeholder="Admin email" autocomplete="off" required />
      <input class="login-inp" type="password" name="password" placeholder="Password" required />
      <button class="login-btn" type="submit">Login to Admin Panel</button>
    </form>

    <div class="login-hint">
      Use credentials from your <code>.env</code> file.
    </div>
  </div>
</div>
