<% const page = 'students' %>
<%- include('layout-start') %>

<div class="topbar">
  <div class="topbar-title">👤 <%= student.studentName %></div>
  <div class="topbar-right">
    <a href="/admin/students" class="btn btn-gray">← Back</a>
    <a href="https://wa.me/91<%= student.phone.replace(/\D/g,'') %>" target="_blank" class="btn btn-green">💬 WhatsApp</a>
  </div>
</div>

<% if (success && success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
<% if (error   && error.length)   { %><div class="alert alert-error"  ><%= error[0]   %></div><% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">

  <!-- Student Info Card -->
  <div class="form-card">
    <h3 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border)">Student Details</h3>
    <div class="detail-grid">
      <div class="detail-item"><label>Student Name</label><div class="val"><%= student.studentName %></div></div>
      <div class="detail-item"><label>Parent Name</label><div class="val"><%= student.parentName || '—' %></div></div>
      <div class="detail-item"><label>Phone / WhatsApp</label><div class="val"><a href="tel:<%= student.phone %>" style="color:var(--green2);text-decoration:none"><%= student.phone %></a></div></div>
      <div class="detail-item"><label>Email</label><div class="val" style="font-size:0.85rem"><%= student.email || '—' %></div></div>
      <div class="detail-item"><label>Class</label><div class="val"><%= student.className %></div></div>
      <div class="detail-item"><label>Batch</label><div class="val"><%= student.batchName || '—' %></div></div>
      <div class="detail-item"><label>Status</label><div class="val"><span class="badge badge-<%= student.status %>"><%= student.status.toUpperCase() %></span></div></div>
      <div class="detail-item"><label>Fee Status</label><div class="val"><span class="badge badge-<%= student.feeStatus %>"><%= student.feeStatus.toUpperCase() %></span></div></div>
      <div class="detail-item"><label>Enrolled On</label><div class="val" style="font-size:0.85rem"><%= new Date(student.enrolledAt).toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'}) %></div></div>
      <% if(student.confirmedAt){ %>
      <div class="detail-item"><label>Confirmed On</label><div class="val" style="font-size:0.85rem"><%= new Date(student.confirmedAt).toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'}) %></div></div>
      <% } %>
    </div>
    <% if(student.message){ %>
    <div style="margin-top:20px;padding:14px;background:var(--sur2);border-radius:10px;border:1px solid var(--border)">
      <label style="margin-bottom:6px">Message from Student</label>
      <p style="font-size:0.87rem;color:var(--muted);line-height:1.7;font-style:italic">"<%= student.message %>"</p>
    </div>
    <% } %>
  </div>

  <!-- Update Card -->
  <div class="form-card">
    <h3 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border)">Update Student</h3>
    <form action="/admin/students/<%= student._id %>/status" method="POST">
      <div class="fg">
        <label>Enrollment Status</label>
        <select name="status">
          <option value="pending"   <%= student.status==='pending'   ? 'selected':'' %>>Pending</option>
          <option value="confirmed" <%= student.status==='confirmed' ? 'selected':'' %>>Confirmed</option>
          <option value="cancelled" <%= student.status==='cancelled' ? 'selected':'' %>>Cancelled</option>
        </select>
      </div>
      <div class="fg">
        <label>Fee Status</label>
        <select name="feeStatus">
          <option value="unpaid"  <%= student.feeStatus==='unpaid'  ? 'selected':'' %>>Unpaid</option>
          <option value="partial" <%= student.feeStatus==='partial' ? 'selected':'' %>>Partial</option>
          <option value="paid"    <%= student.feeStatus==='paid'    ? 'selected':'' %>>Paid</option>
        </select>
      </div>
      <div class="fg">
        <label>Admin Notes</label>
        <textarea name="notes" rows="3" placeholder="Internal notes about this student..."><%= student.notes || '' %></textarea>
      </div>
      <button type="submit" class="btn btn-solid" style="width:100%;padding:12px">💾 Save Changes</button>
    </form>

    <div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--border)">
      <h4 style="font-size:0.82rem;font-weight:700;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:12px">Quick Actions</h4>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a href="tel:<%= student.phone %>" class="btn btn-green">📞 Call</a>
        <a href="https://wa.me/91<%= student.phone.replace(/\D/g,'') %>?text=Hello%20<%= encodeURIComponent(student.studentName) %>%2C%20this%20is%20Akram%20Sir%20from%20Akram%20Biology.%20Your%20enrollment%20has%20been%20confirmed!" target="_blank" class="btn btn-green">💬 Send WhatsApp</a>
      </div>
    </div>

    <div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--border)">
      <h4 style="font-size:0.82rem;font-weight:700;color:#f87171;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px">Danger Zone</h4>
      <form action="/admin/students/<%= student._id %>/delete" method="POST" onsubmit="return confirm('Remove <%= student.studentName %>? This cannot be undone.')">
        <button type="submit" class="btn btn-red">🗑 Remove Student</button>
      </form>
    </div>
  </div>
</div>

<%- include('layout-end') %>
