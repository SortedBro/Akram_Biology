<%- include('layout-start') %>

<div class="topbar">
  <div class="topbar-title">👤 <%= student.studentName %></div>
  <div class="topbar-right">
    <a href="/admin/students" class="btn btn-gray">← Back</a>
    <a href="/admin/fees" class="btn btn-green">💰 Fees Overview</a>
    <a href="https://wa.me/91<%= student.phone.replace(/\D/g,'') %>" target="_blank" class="btn btn-green">💬 WhatsApp</a>
  </div>
</div>

<% if (success && success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
<% if (error   && error.length)   { %><div class="alert alert-error"  ><%= error[0]   %></div><% } %>

<!-- TOP ROW: Info + Update -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">

  <!-- Student Info -->
  <div class="form-card">
    <h3 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border)">Student Details</h3>
    <div class="detail-grid">
      <div class="detail-item"><label>Student Name</label><div class="val"><%= student.studentName %></div></div>
      <div class="detail-item"><label>Parent Name</label><div class="val"><%= student.parentName || '—' %></div></div>
      <div class="detail-item"><label>Phone / WhatsApp</label><div class="val"><a href="tel:<%= student.phone %>" style="color:var(--green2);text-decoration:none"><%= student.phone %></a></div></div>
      <div class="detail-item"><label>Email</label><div class="val" style="font-size:0.83rem"><%= student.email || '—' %></div></div>
      <div class="detail-item"><label>Class</label><div class="val"><%= student.className %></div></div>
      <div class="detail-item"><label>Batch</label><div class="val"><%= student.batchName || '—' %></div></div>
      <div class="detail-item"><label>Status</label><div class="val"><span class="badge badge-<%= student.status %>"><%= student.status.toUpperCase() %></span></div></div>
      <div class="detail-item"><label>Enrolled On</label><div class="val" style="font-size:0.83rem"><%= new Date(student.enrolledAt).toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'}) %></div></div>
    </div>
    <% if(student.message){ %>
    <div style="margin-top:18px;padding:12px 14px;background:var(--sur2);border-radius:10px;border:1px solid var(--border)">
      <label style="margin-bottom:6px">Message from Student</label>
      <p style="font-size:0.86rem;color:var(--muted);line-height:1.7;font-style:italic">"<%= student.message %>"</p>
    </div>
    <% } %>
  </div>

  <!-- Update -->
  <div class="form-card">
    <h3 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border)">Update Student</h3>
    <form action="/admin/students/<%= student._id %>/status" method="POST">
      <div class="fg">
        <label>Enrollment Status</label>
        <select name="status">
          <option value="pending"   <%= student.status==='pending'   ?'selected':'' %>>Pending</option>
          <option value="confirmed" <%= student.status==='confirmed' ?'selected':'' %>>Confirmed</option>
          <option value="cancelled" <%= student.status==='cancelled' ?'selected':'' %>>Cancelled</option>
        </select>
      </div>
      <div class="fg">
        <label>Admin Notes</label>
        <textarea name="notes" rows="3" placeholder="Internal notes..."><%= student.notes || '' %></textarea>
      </div>
      <button type="submit" class="btn btn-solid" style="width:100%;padding:11px">💾 Save Changes</button>
    </form>

    <div style="margin-top:18px;padding-top:18px;border-top:1px solid var(--border)">
      <h4 style="font-size:0.78rem;font-weight:700;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:10px">Quick Actions</h4>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <a href="tel:<%= student.phone %>" class="btn btn-green">📞 Call</a>
        <a href="https://wa.me/91<%= student.phone.replace(/\D/g,'') %>?text=Hello%20<%= encodeURIComponent(student.studentName) %>%2C%20this%20is%20Akram%20Sir!" target="_blank" class="btn btn-green">💬 WhatsApp</a>
      </div>
    </div>

    <div style="margin-top:18px;padding-top:18px;border-top:1px solid var(--border)">
      <h4 style="font-size:0.78rem;font-weight:700;color:#f87171;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px">Danger Zone</h4>
      <form action="/admin/students/<%= student._id %>/delete" method="POST" onsubmit="return confirm('Remove <%= student.studentName %>? This cannot be undone.')">
        <button type="submit" class="btn btn-red">🗑 Remove Student</button>
      </form>
    </div>
  </div>
</div>

<!-- ══ FEES PANEL ═══════════════════════════════════════════ -->
<div class="form-card" style="margin-bottom:20px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border)">
    <h3 style="font-family:'Playfair Display',serif;font-size:1.2rem">💰 Fee History — Last 12 Months</h3>
    <button onclick="document.getElementById('addFeeForm').style.display = document.getElementById('addFeeForm').style.display==='none'?'block':'none'"
            class="btn btn-green">+ Record Fee</button>
  </div>

  <!-- Add fee form (hidden by default) -->
  <div id="addFeeForm" style="display:none;background:var(--sur2);border:1px solid var(--border);border-radius:12px;padding:22px;margin-bottom:20px">
    <h4 style="font-size:0.85rem;font-weight:700;color:var(--green3);margin-bottom:16px;letter-spacing:0.5px">Record Fee Payment</h4>
    <form action="/admin/students/<%= student._id %>/fee" method="POST">
      <div class="form-row3">
        <div class="fg">
          <label>Month</label>
          <select name="month">
            <% MONTHS.forEach(function(m,i){ %>
            <option value="<%= i %>" <%= i===new Date().getMonth() ? 'selected':'' %>><%= m %></option>
            <% }); %>
          </select>
        </div>
        <div class="fg">
          <label>Year</label>
          <select name="year">
            <% for(let y=new Date().getFullYear(); y>=new Date().getFullYear()-2; y--){ %>
            <option value="<%= y %>" <%= y===new Date().getFullYear() ? 'selected':'' %>><%= y %></option>
            <% } %>
          </select>
        </div>
        <div class="fg">
          <label>Status</label>
          <select name="status">
            <option value="paid">✅ Paid</option>
            <option value="partial">🟡 Partial</option>
            <option value="unpaid">❌ Unpaid</option>
          </select>
        </div>
      </div>
      <div class="form-row2">
        <div class="fg">
          <label>Amount (₹)</label>
          <input type="number" name="amount" placeholder="e.g. 700" min="0">
        </div>
        <div class="fg">
          <label>Note (optional)</label>
          <input type="text" name="note" placeholder="UPI, cash, ref no...">
        </div>
      </div>
      <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-solid" style="padding:10px 24px">💾 Save Fee Record</button>
        <button type="button" onclick="document.getElementById('addFeeForm').style.display='none'" class="btn btn-gray" style="padding:10px 16px">Cancel</button>
      </div>
    </form>
  </div>

  <!-- 12-month grid -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px">
    <% last12.forEach(function(item){ %>
    <%
      const isCurrentMonth = item.month === new Date().getMonth() && item.year === new Date().getFullYear();
      const rec = item.record;
      let bg = 'rgba(239,68,68,0.06)';
      let borderColor = 'rgba(239,68,68,0.2)';
      let statusColor = '#f87171';
      let statusText = 'UNPAID';
      let icon = '❌';
      if(rec && rec.status === 'paid')    { bg='rgba(34,197,94,0.06)';  borderColor='rgba(34,197,94,0.25)';  statusColor='#4ade80'; statusText='PAID';    icon='✅'; }
      if(rec && rec.status === 'partial') { bg='rgba(245,158,11,0.06)'; borderColor='rgba(245,158,11,0.25)'; statusColor='#fbbf24'; statusText='PARTIAL'; icon='🟡'; }
    %>
    <div style="background:<%= bg %>;border:1px solid <%= borderColor %>;border-radius:12px;padding:14px;position:relative;
                <%= isCurrentMonth ? 'outline:2px solid var(--green);outline-offset:2px' : '' %>">
      <% if(isCurrentMonth){ %>
      <div style="position:absolute;top:-8px;right:8px;background:var(--green);color:#fff;font-size:0.62rem;font-weight:700;padding:2px 8px;border-radius:10px;letter-spacing:0.5px">THIS MONTH</div>
      <% } %>
      <div style="font-size:0.78rem;font-weight:700;color:var(--muted);margin-bottom:4px"><%= item.monthName %> <%= item.year %></div>
      <div style="font-size:1.2rem;margin-bottom:6px"><%= icon %></div>
      <div style="font-size:0.7rem;font-weight:800;letter-spacing:1px;color:<%= statusColor %>"><%= statusText %></div>
      <% if(rec && rec.amount){ %>
      <div style="font-size:0.82rem;font-weight:700;color:var(--text);margin-top:4px">₹<%= rec.amount.toLocaleString('en-IN') %></div>
      <% } %>
      <% if(rec && rec.paidAt){ %>
      <div style="font-size:0.7rem;color:var(--muted);margin-top:2px"><%= new Date(rec.paidAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short'}) %></div>
      <% } %>
      <% if(rec && rec.note){ %>
      <div style="font-size:0.68rem;color:var(--muted);margin-top:4px;font-style:italic;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="<%= rec.note %>"><%= rec.note %></div>
      <% } %>
    </div>
    <% }); %>
  </div>

  <!-- Summary row -->
  <%
    const paidCount    = last12.filter(i => i.record && i.record.status==='paid').length;
    const unpaidCount  = last12.filter(i => !i.record || i.record.status==='unpaid').length;
    const partialCount = last12.filter(i => i.record && i.record.status==='partial').length;
    const totalPaid    = last12.reduce((a,i) => a + (i.record && i.record.status==='paid' ? i.record.amount : 0), 0);
  %>
  <div style="display:flex;gap:16px;margin-top:18px;padding-top:16px;border-top:1px solid var(--border);flex-wrap:wrap">
    <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:12px 18px;text-align:center">
      <div style="font-size:1.3rem;font-weight:900;color:var(--green2)"><%= paidCount %></div>
      <div style="font-size:0.72rem;color:var(--muted)">Months Paid</div>
    </div>
    <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:10px;padding:12px 18px;text-align:center">
      <div style="font-size:1.3rem;font-weight:900;color:#f87171"><%= unpaidCount %></div>
      <div style="font-size:0.72rem;color:var(--muted)">Months Unpaid</div>
    </div>
    <div style="background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.2);border-radius:10px;padding:12px 18px;text-align:center">
      <div style="font-size:1.3rem;font-weight:900;color:var(--warn)"><%= partialCount %></div>
      <div style="font-size:0.72rem;color:var(--muted)">Months Partial</div>
    </div>
    <div style="background:rgba(163,230,53,0.08);border:1px solid rgba(163,230,53,0.2);border-radius:10px;padding:12px 18px;text-align:center">
      <div style="font-size:1.3rem;font-weight:900;color:var(--lime)">₹<%= totalPaid.toLocaleString('en-IN') %></div>
      <div style="font-size:0.72rem;color:var(--muted)">Total Collected</div>
    </div>
  </div>
</div>

<%- include('layout-end') %>
