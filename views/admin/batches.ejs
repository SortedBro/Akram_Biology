<% const page = 'batches' %>
<%- include('layout-start') %>

<div class="topbar">
  <div class="topbar-title">📅 Batches</div>
  <div class="topbar-right">
    <span class="admin-badge"><%= batches.length %> batches</span>
  </div>
</div>

<% if (success && success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
<% if (error   && error.length)   { %><div class="alert alert-error"  ><%= error[0]   %></div><% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">

  <!-- Existing Batches -->
  <div>
    <h3 style="font-family:'Playfair Display',serif;font-size:1.1rem;margin-bottom:16px">Active Batches</h3>
    <div style="display:flex;flex-direction:column;gap:14px">
      <% if(batches.length){ batches.forEach(function(b){ %>
      <div class="form-card" style="padding:20px">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px">
          <div>
            <div style="font-weight:700;font-size:0.95rem;margin-bottom:2px"><%= b.name %></div>
            <div style="font-size:0.78rem;color:var(--muted)"><%= b.className %></div>
          </div>
          <span class="badge badge-<%= b.isActive ? 'active':'inactive' %>"><%= b.isActive ? 'Active':'Inactive' %></span>
        </div>

        <div class="days-list" style="margin-bottom:10px">
          <% b.days.forEach(function(d){ %><span class="day-chip"><%= d %></span><% }); %>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;font-size:0.8rem;margin-bottom:12px">
          <div style="color:var(--muted)">⏰ <%= b.time %></div>
          <div style="color:var(--green2);font-weight:700">₹<%= b.fee %>/mo</div>
          <div style="color:var(--muted)"><%= b.currentStudents %>/<%= b.maxStudents %> students</div>
        </div>

        <!-- Progress bar -->
        <div style="background:var(--sur2);border-radius:6px;overflow:hidden;height:6px;margin-bottom:12px">
          <div style="height:100%;width:<%= Math.min((b.currentStudents/b.maxStudents)*100,100) %>%;background:linear-gradient(90deg,#166534,#22c55e);border-radius:6px"></div>
        </div>

        <% if(b.description){ %>
        <p style="font-size:0.78rem;color:var(--muted);margin-bottom:12px;line-height:1.5"><%= b.description %></p>
        <% } %>

        <div style="display:flex;gap:8px">
          <form action="/admin/batches/<%= b._id %>/toggle" method="POST">
            <button type="submit" class="btn btn-green" style="font-size:0.78rem;padding:6px 12px">
              <%= b.isActive ? '⏸ Deactivate' : '▶ Activate' %>
            </button>
          </form>
          <form action="/admin/batches/<%= b._id %>/delete" method="POST" onsubmit="return confirm('Delete this batch?')">
            <button type="submit" class="btn btn-red" style="font-size:0.78rem;padding:6px 12px">🗑 Delete</button>
          </form>
        </div>
      </div>
      <% }); } else { %>
      <div class="empty-state"><div class="emoji">📅</div><p>No batches yet. Add one →</p></div>
      <% } %>
    </div>
  </div>

  <!-- Add New Batch -->
  <div class="form-card">
    <h3 style="font-family:'Playfair Display',serif;font-size:1.1rem;margin-bottom:20px">Add New Batch</h3>
    <form action="/admin/batches/add" method="POST">
      <div class="fg"><label>Batch Name</label><input type="text" name="name" placeholder="e.g. Class 11 Morning Batch" required></div>
      <div class="fg">
        <label>Class</label>
        <select name="className" required>
          <option value="">Select class</option>
          <% ['Class 9','Class 10','Class 11','Class 12','NEET Dropper'].forEach(function(c){ %>
          <option value="<%= c %>"><%= c %></option>
          <% }); %>
        </select>
      </div>
      <div class="fg">
        <label>Days (select multiple)</label>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:4px">
          <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].forEach(function(d){ %>
          <label style="display:flex;align-items:center;gap:6px;text-transform:none;letter-spacing:0;font-size:0.84rem;cursor:pointer">
            <input type="checkbox" name="days" value="<%= d %>" style="width:auto;padding:0;border:none;background:none"> <%= d %>
          </label>
          <% }); %>
        </div>
      </div>
      <div class="form-row2">
        <div class="fg"><label>Time</label><input type="text" name="time" placeholder="4:00 PM – 6:00 PM" required></div>
        <div class="fg"><label>Monthly Fee (₹)</label><input type="number" name="fee" placeholder="600" required></div>
      </div>
      <div class="fg"><label>Max Students</label><input type="number" name="maxStudents" value="15" min="1" max="50"></div>
      <div class="fg"><label>Description (optional)</label><textarea name="description" rows="2" placeholder="Brief description of what's covered..."></textarea></div>
      <button type="submit" class="btn btn-solid" style="width:100%;padding:12px">+ Add Batch</button>
    </form>
  </div>
</div>

<%- include('layout-end') %>
