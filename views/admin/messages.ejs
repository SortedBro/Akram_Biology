<% const page = 'messages' %>
<%- include('layout-start') %>

<div class="topbar">
  <div class="topbar-title">💬 Messages</div>
  <div class="topbar-right">
    <span class="admin-badge"><%= messages.length %> total</span>
  </div>
</div>

<% if (success && success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>

<% if(messages.length){ %>
<div style="display:flex;flex-direction:column;gap:14px">
  <% messages.forEach(function(m){ %>
  <div class="form-card" style="padding:22px;display:flex;gap:20px;align-items:flex-start">
    <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#0f3d20,#22c55e);display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;flex-shrink:0;font-size:1rem">
      <%= m.name.charAt(0).toUpperCase() %>
    </div>
    <div style="flex:1">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <div>
          <strong style="font-size:0.95rem"><%= m.name %></strong>
          <a href="tel:<%= m.phone %>" style="color:var(--green3);text-decoration:none;font-size:0.82rem;margin-left:12px"><%= m.phone %></a>
        </div>
        <span style="font-size:0.75rem;color:var(--muted)">
          <%= new Date(m.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
        </span>
      </div>
      <p style="font-size:0.88rem;color:var(--muted);line-height:1.7;font-style:italic">"<%= m.message %>"</p>
      <div style="display:flex;gap:8px;margin-top:12px">
        <a href="tel:<%= m.phone %>" class="btn btn-green" style="font-size:0.78rem;padding:6px 12px">📞 Call</a>
        <a href="https://wa.me/91<%= m.phone.replace(/\D/g,'') %>?text=Hello%20<%= encodeURIComponent(m.name) %>%2C%20this%20is%20Akram%20Sir%20from%20Akram%20Biology!" target="_blank" class="btn btn-green" style="font-size:0.78rem;padding:6px 12px">💬 WhatsApp</a>
        <form action="/admin/messages/<%= m._id %>/delete" method="POST" onsubmit="return confirm('Delete this message?')" style="margin:0">
          <button type="submit" class="btn btn-red" style="font-size:0.78rem;padding:6px 12px">🗑 Delete</button>
        </form>
      </div>
    </div>
  </div>
  <% }); %>
</div>
<% } else { %>
<div class="empty-state" style="padding:80px 20px">
  <div class="emoji">💬</div>
  <p>No messages yet. They'll appear here when students send enquiries from the website.</p>
</div>
<% } %>

<%- include('layout-end') %>
