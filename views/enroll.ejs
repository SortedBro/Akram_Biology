<%- include('partials/head') %>
<%- include('partials/navbar') %>
<canvas id="bio-canvas" style="position:fixed;inset:0;z-index:0;opacity:0.25;pointer-events:none"></canvas>

<div style="min-height:100vh;padding-top:100px;position:relative;z-index:1">
  <section class="section">
    <div style="text-align:center;margin-bottom:52px">
      <div class="sec-label">Enrollment</div>
      <h1 class="sec-title">Secure Your Seat</h1>
      <p class="sec-sub" style="margin:0 auto">Fill in your details and Akram Sir will personally call to confirm your enrollment within 24 hours.</p>
    </div>

    <% if (success && success.length) { %>
      <div class="alert alert-success" style="max-width:640px;margin:0 auto 24px"><%= success[0] %></div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="alert alert-error" style="max-width:640px;margin:0 auto 24px"><%= error[0] %></div>
    <% } %>

    <div class="enroll-box" style="max-width:960px;margin:0 auto">
      <!-- Left Info -->
      <div class="enroll-left">
        <div class="sec-label">Why Join?</div>
        <h2 style="font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:900;letter-spacing:-0.5px;line-height:1.2;margin-bottom:16px">
          Learn From The Best Biology Teacher in Lohapur
        </h2>
        <p style="font-size:0.88rem;color:var(--muted);line-height:1.8;font-weight:300;margin-bottom:28px">
          Join hundreds of successful students who cracked NEET and scored top marks in boards under Akram Sir's guidance.
        </p>
        <div class="enroll-features">
          <div class="ef-item"><div class="ef-check">✓</div><span class="ef-text">Free first demo class</span></div>
          <div class="ef-item"><div class="ef-check">✓</div><span class="ef-text">Small batch — max 15 students</span></div>
          <div class="ef-item"><div class="ef-check">✓</div><span class="ef-text">Chapter-wise notes &amp; diagrams</span></div>
          <div class="ef-item"><div class="ef-check">✓</div><span class="ef-text">Monthly NEET mock tests</span></div>
          <div class="ef-item"><div class="ef-check">✓</div><span class="ef-text">WhatsApp doubt support</span></div>
          <div class="ef-item"><div class="ef-check">✓</div><span class="ef-text">Confirmation call within 24 hrs</span></div>
        </div>

        <div style="margin-top:36px;padding:20px;background:rgba(34,197,94,0.06);border:1px solid rgba(34,197,94,0.15);border-radius:12px">
          <div style="font-size:0.78rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--lime);margin-bottom:10px">Fees at a Glance</div>
          <% if(batches && batches.length){ batches.forEach(function(b){ %>
          <div style="display:flex;justify-content:space-between;font-size:0.85rem;padding:6px 0;border-bottom:1px solid var(--border)">
            <span style="color:var(--muted)"><%= b.className %></span>
            <span style="font-weight:700;color:var(--green2)">₹<%= b.fee %>/month</span>
          </div>
          <% }); } %>
        </div>
      </div>

      <!-- Right Form -->
      <div class="enroll-right">
        <h3 style="font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:900;margin-bottom:24px">Enrollment Form</h3>
        <form action="/enroll" method="POST" class="form-stack">
          <div class="form-row2">
            <div class="fg"><label>Student Name *</label><input type="text" name="studentName" placeholder="Full name" required></div>
            <div class="fg"><label>Parent's Name</label><input type="text" name="parentName" placeholder="Guardian name"></div>
          </div>
          <div class="fg"><label>WhatsApp Number *</label><input type="tel" name="phone" placeholder="+91 98765 43210" required></div>
          <div class="fg"><label>Email Address</label><input type="email" name="email" placeholder="student@gmail.com"></div>
          <div class="form-row2">
            <div class="fg">
              <label>Class *</label>
              <select name="className" required>
                <option value="">Select class</option>
                <option>Class 9</option>
                <option>Class 10</option>
                <option>Class 11</option>
                <option>Class 12</option>
                <option>NEET Dropper</option>
              </select>
            </div>
            <div class="fg">
              <label>Preferred Batch</label>
              <select name="batchId">
                <option value="">To be confirmed</option>
                <% if(batches){ batches.forEach(function(b){ %>
                <option value="<%= b._id %>" <%= b.isFull ? 'disabled' : '' %>>
                  <%= b.name %> — ₹<%= b.fee %>/mo <%= b.isFull ? '(FULL)' : '' %>
                </option>
                <% }); } %>
              </select>
            </div>
          </div>
          <div class="fg"><label>Message (Optional)</label><textarea name="message" placeholder="Any questions or special requirements for Akram Sir..."></textarea></div>
          <button type="submit" class="form-btn">🌱 Submit Enrollment Request</button>
          <p class="form-note">Akram Sir will personally call you within 24 hours to confirm your seat and answer any questions.</p>
        </form>
      </div>
    </div>
  </section>
</div>

<style>.reveal{opacity:0;transform:translateY(28px);transition:all 0.75s ease}.reveal.in{opacity:1;transform:none}</style>
<%- include('partials/footer') %>
